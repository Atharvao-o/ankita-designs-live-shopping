# Local development can call the backend directly.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Vercel production should set this to the Render backend URL, for example:
# BACKEND_API_URL=https://your-render-service.onrender.com
# Leave NEXT_PUBLIC_API_URL empty in Vercel if you want the built-in /api/backend proxy.
BACKEND_API_URL=
